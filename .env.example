# ============================================================
# Copy to .env and fill in. Only AI_PROVIDER is required to run
# the demo (defaults to 'mock' — no keys needed).
# ============================================================

# --- Store ---
STORE_NAME=Aurora Store
STORE_CURRENCY=USD
DB_PATH=convo_commerce.db
PAYMENT_LINK_BASE=https://pay.example.com/checkout

# --- AI brain: mock | claude | openai | gemini ---
AI_PROVIDER=gemini
AI_TEMPERATURE=0.3
AI_MAX_TOOL_ITERATIONS=6

# Model names (override defaults if desired)
CLAUDE_MODEL=claude-sonnet-4-5
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.0-flash

# API keys (only the selected provider's key is needed)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=<your_ai_studio_key>

# --- WhatsApp Business (Cloud API) ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# --- Facebook Messenger ---
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_VERIFY_TOKEN=
MESSENGER_APP_SECRET=

# Shared Graph API version
GRAPH_API_VERSION=v21.0
